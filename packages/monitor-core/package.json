{
  "name": "pulsemachine",
  "version": "0.1.1",
  "description": "Lightweight system monitoring library inspired by Grafana, Netdata, and PM2",
  "license": "MIT",
  "author": "MyOrg",
  "repository": {
    "type": "git",
    "url": "https://github.com/myorg/monitor-core.git",
    "directory": "packages/monitor-core"
  },
  "homepage": "https://github.com/myorg/monitor-core#readme",
  "bugs": {
    "url": "https://github.com/myorg/monitor-core/issues"
  },
  "keywords": [
    "monitoring",
    "system-metrics",
    "prometheus",
    "websocket",
    "docker",
    "alerts"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./cli": {
      "import": {
        "types": "./dist/cli/index.d.ts",
        "default": "./dist/cli/index.js"
      },
      "require": {
        "types": "./dist/cli/index.d.cts",
        "default": "./dist/cli/index.cjs"
      }
    },
    "./prometheus": {
      "import": {
        "types": "./dist/adapters/prometheus.adapter.d.ts",
        "default": "./dist/adapters/prometheus.adapter.js"
      },
      "require": {
        "types": "./dist/adapters/prometheus.adapter.d.cts",
        "default": "./dist/adapters/prometheus.adapter.cjs"
      }
    },
    "./websocket": {
      "import": {
        "types": "./dist/adapters/websocket.adapter.d.ts",
        "default": "./dist/adapters/websocket.adapter.js"
      },
      "require": {
        "types": "./dist/adapters/websocket.adapter.d.cts",
        "default": "./dist/adapters/websocket.adapter.cjs"
      }
    }
  },
  "bin": {
    "pulsemachine": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "PLUGIN_GUIDE.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "lint": "eslint src tests examples",
    "lint:fix": "eslint src tests examples --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "prom-client": "^15.1.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@eslint/js": "^9.17.0",
    "@types/blessed": "^0.1.25",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
